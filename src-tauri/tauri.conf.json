{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Salem",
  "version": "0.1.0",
  "identifier": "com.jiyapatel.salem-the-black-cat",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Salem",
        "width": 220,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Salem Settings",
        "width": 300,
        "height": 340,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "resizable": false,
        "visible": false,
        "url": "index.html?window=settings"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}